# Environment variables for the RAG system
# Copy this file to .env and fill in your values

# Google Gemini API Configuration
# ==================

# REQUIRED: Your Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
LLM_API_KEY=AIzaSyA-UWg198WXFz8gZ2ln_xUCsLJ-WhwBv1s

# OPTIONAL: Gemini Model Name
# Options:
#   - gemini-1.5-flash (recommended: fast and cost-effective)
#   - gemini-1.5-pro (higher quality, more expensive)
#   - gemini-pro (older model)
LLM_MODEL_NAME=gemini-1.5-flash

# Logging
# ==================
LOG_LEVEL=INFO

# Optional: Custom paths
# ==================
# Uncomment to override default paths

# PAPERS_DIR=./papers
# CHROMA_DB_DIR=./chroma_db
# MODELS_CACHE_DIR=./models
