# ==============================================================================
# IndicRAG — Environment Configuration
# Copy this file to .env and fill in the required values.
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#
# NEVER commit .env to version control — it contains secrets.
# ==============================================================================


# ==============================================================================
# LLM — Google Gemini (REQUIRED)
# ==============================================================================

# Get your API key at: https://aistudio.google.com/app/apikey
LLM_API_KEY=your-gemini-api-key-here

# Model to use for answer generation.
# Recommended: gemini-3.5-flash — stable, frontier-level, fast, cost-effective.
# Alternatives:
#   gemini-3-flash-preview   Preview alias (same model)
#   gemini-2.5-pro           Higher reasoning quality, slower and more expensive
LLM_MODEL_NAME=gemini-3.5-flash

# Response generation parameters
# Temperature: 0.0 = fully deterministic / factual, 1.0 = creative
LLM_TEMPERATURE=0.3
# Maximum tokens to generate per response
LLM_MAX_TOKENS=2048


# ==============================================================================
# API Security (Optional — leave empty for local development)
# ==============================================================================

# Comma-separated list of valid API keys clients must send via X-API-Key header.
# If empty, the server accepts all requests without authentication.
# WARNING: If set, the frontend must also send this key or all UI queries will
# fail with 401 Unauthorized.
# Example: API_KEYS=secret-key-1,secret-key-2
API_KEYS=


# ==============================================================================
# Logging
# ==============================================================================

# Verbosity level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ==============================================================================
# HuggingFace / Embedding Model Cache (Optional)
# ==============================================================================

# Embedding models (multilingual-e5-base) are cached to the models/ directory.
# On Windows, HuggingFace may log symlink warnings — suppress them by
# uncommenting the line below:
# HF_HUB_DISABLE_SYMLINKS_WARNING=1


# ==============================================================================
# Translation — Strategy B (Optional)
# ==============================================================================

# Strategy B translates non-English queries to English before retrieval,
# then translates the answer back to the original language.
# The NLLB-200 model (~2.5 GB) is downloaded automatically on first use.
# Model: facebook/nllb-200-distilled-600M
