# ==============================================================================
# Multilingual Scientific RAG System - Environment Configuration
# ==============================================================================

# ==============================================================================
# Google Gemini API Configuration (REQUIRED)
# ==============================================================================

# Your Google Gemini API Key
# Get your key at: https://ai.google.dev/
LLM_API_KEY=your-actual-api-key-here

# Gemini Model Selection
# Options: gemini-flash-latest, gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL_NAME=gemini-flash-latest

# LLM Generation Parameters
# Temperature: 0.0-1.0 (lower = more factual, higher = more creative)
LLM_TEMPERATURE=0.3
# Max tokens to generate in response
LLM_MAX_TOKENS=2048

# ==============================================================================
# API Security (Optional)
# ==============================================================================

# API Key Authentication (comma-separated list)
# Leave empty/commented for no authentication
# API_KEYS=key1,key2,key3

# ==============================================================================
# Logging Configuration
# ==============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==============================================================================
# Model Cache Configuration
# ==============================================================================

# Suppress HuggingFace symlink warnings on Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1
