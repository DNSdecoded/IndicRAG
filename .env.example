# Environment variables for the RAG system
# IMPORTANT: Add your actual Google Gemini API key below

# Google Gemini API Configuration
# ==================

# REQUIRED: Your Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
# Replace 'your-gemini-api-key-here' with your actual API key
LLM_API_KEY=<Your_API_Key>

# OPTIONAL: Gemini Model Name
# Options:
#   - gemini-2.5-flash (recommended: fast and cost-effective)
#   - gemini-2.5-pro (higher quality)
#   - gemini-flash-latest (always uses latest)
LLM_MODEL_NAME=gemini-flash-latest

# Logging
# ==================
LOG_LEVEL=INFO

# Optional: Custom paths
# ==================
# Uncomment to override default paths

# PAPERS_DIR=./papers
# CHROMA_DB_DIR=./chroma_db
# MODELS_CACHE_DIR=./models
